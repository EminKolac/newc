{
  "permissions": {
    "allow": [],
    "deny": []
  },
  "mcpServers": {
    "fintables": {
      "type": "http",
      "url": "https://evo.fintables.com/mcp"
    },
    "yfinance": {
      "command": "uvx",
      "args": ["mcp-yahoo-finance"],
      "env": {}
    },
    "apify": {
      "command": "npx",
      "args": [
        "-y",
        "@apify/actors-mcp-server",
        "--actors",
        "apify/twitter-scraper,apify/google-news-scraper,apify/google-trends-scraper,apify/web-scraper"
      ],
      "env": {
        "APIFY_TOKEN": "YOUR_APIFY_TOKEN_HERE"
      }
    }
  }
}
